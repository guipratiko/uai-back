PORT=3333
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uaitickets?schema=public
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
# Origens permitidas (vírgula). NÃO use o nome CORS_ORIGIN no painel — alguns hosts injetam isso como header HTTP.
ALLOWED_ORIGINS=http://localhost:3000,https://uaitickets.com.br,https://www.uaitickets.com.br
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3333
ADMIN_EMAIL=admin@uaitickets.com.br
ADMIN_PASSWORD=change-me
SERVICE_FEE_RATE=0.1
UPLOADS_DIR=uploads
PASSWORD_RESET_EXPIRES_HOURS=1

# E-mail (SMTP) — ingressos e recuperação de senha
# Umbler: porta 587 + SMTP_SECURE=false (STARTTLS). Porta 465 = SMTP_SECURE=true
SMTP_ENABLED=false
SMTP_HOST=smtp.umbler.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=suporte@uaitickets.com.br
SMTP_PASS=
# Deve ser o mesmo e-mail do SMTP_USER (Umbler exige)
EMAIL_FROM=suporte@uaitickets.com.br
# SMTP_DEBUG=true
# TEST_EMAIL_TO=seu@email.com
EMAIL_FROM_NAME=Uai Tickets

# Asaas
ASAAS_API_KEY=
ASAAS_API_URL=https://api-sandbox.asaas.com
ASAAS_WEBHOOK_TOKEN=
ASAAS_CHECKOUT_EXPIRE_MINUTES=30
# URLs HTTPS de retorno após pagamento (obrigatório; localhost é rejeitado pelo Asaas)
# Em dev local: use ngrok ou deixe vazio para usar https://uaitickets.com.br
# ASAAS_CALLBACK_URL=https://seu-tunnel.ngrok-free.app
