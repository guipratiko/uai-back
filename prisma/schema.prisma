generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum UserGender {
  male
  female
  unspecified
}

enum OrderStatus {
  pending
  confirmed
  cancelled
  expired
}

enum TicketStatus {
  approved
  pending
}

enum PaymentMethod {
  pix
  credit_card
}

enum TicketSource {
  sale
  courtesy
}

enum TicketTierStatus {
  scheduled
  active
  closed
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  fullName             String
  cpf                  String                @default("")
  phone                String                @default("")
  gender               UserGender            @default(unspecified)
  city                 String                @default("")
  state                String                @default("")
  avatarUrl            String?
  role                 Role                  @default(USER)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  orders               Order[]
  passwordResetTokens  PasswordResetToken[]
  ticketTransfersInitiated TicketTransfer[] @relation("TransferInitiatedBy")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Event {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  subtitle    String
  category    String
  date        String
  endDate     String?
  time        String
  venue       String
  address     String
  city        String
  state       String
  image       String
  bannerImage String
  description String       @db.Text
  highlights  Json
  organizer   String
  ageRating   String
  mapEmbedUrl String       @db.Text
  lat         Float
  lng         Float
  featured             Boolean           @default(false)
  /// % cobrado do comprador (checkout). Null = 10% (padrão).
  buyerFeePercent      Decimal?          @db.Decimal(5, 2)
  /// % da bilheteria retido do produtor (só relatório). Null = 0%.
  platformFeePercent   Decimal?          @db.Decimal(5, 2)
  /// Permite transferência de titularidade (1x por ingresso vendido).
  allowTransfer        Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  tickets              TicketTier[]
  organizerEvents      OrganizerEvent[]
  producerEvents       ProducerEvent[]
}

model Organizer {
  id        String           @id @default(cuid())
  email     String           @unique
  password  String
  name      String
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  events    OrganizerEvent[]
  checkIns  IssuedTicket[]   @relation("CheckedInBy")
}

model OrganizerEvent {
  id          String    @id @default(cuid())
  organizerId String
  eventId     String
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([organizerId, eventId])
  @@index([eventId])
}

model Producer {
  id             String               @id @default(cuid())
  email          String               @unique
  password       String
  name           String
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  events         ProducerEvent[]
  courtesyLogs   ProducerCourtesyLog[]
  createdTickets IssuedTicket[]       @relation("CreatedByProducer")
  courtesyOrders Order[]              @relation("CourtesyOrdersBy")
}

model ProducerEvent {
  id         String   @id @default(cuid())
  producerId String
  eventId    String
  producer   Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([producerId, eventId])
  @@index([eventId])
}

model ProducerCourtesyLog {
  id           String   @id @default(cuid())
  producerId   String
  eventId      String
  ticketTierId String
  ticketName   String
  quantity     Int
  createdAt    DateTime @default(now())
  producer     Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)

  @@index([producerId])
  @@index([eventId])
}

model TicketTier {
  id                   String           @id @default(cuid())
  eventId              String
  event                Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name                 String
  description          String           @db.Text
  price                Decimal          @db.Decimal(10, 2)
  available            Int
  maxPerOrder          Int
  benefits             Json?
  sortOrder            Int              @default(0)
  /// Vazio = tipo em paralelo (VIP, Pista). Mesmo valor em vários tiers = cadeia de virada 1º→2º lote.
  lotChainId           String?
  status               TicketTierStatus @default(active)
  /// Virada por data — o que ocorrer primeiro com maxSales.
  activateAt           DateTime?
  /// Limite de vendas (e opcionalmente cortesias) para virar o próximo lote.
  maxSales             Int?
  soldCount            Int              @default(0)
  /// Se true, cortesias emitidas neste lote entram no soldCount para maxSales.
  countCourtesyInCap   Boolean          @default(false)

  @@index([eventId, status])
  @@index([eventId, sortOrder])
}

model Order {
  id            String         @id @default(cuid())
  userId        String?
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  buyerName     String
  buyerEmail    String
  buyerCpf      String
  buyerPhone    String
  paymentMethod PaymentMethod
  subtotal      Decimal        @db.Decimal(10, 2)
  serviceFee    Decimal        @db.Decimal(10, 2)
  platformFee   Decimal        @default(0) @db.Decimal(10, 2)
  total         Decimal        @db.Decimal(10, 2)
  source               TicketSource   @default(sale)
  status               OrderStatus    @default(pending)
  asaasCheckoutId      String?        @unique
  paidAt               DateTime?
  createdByProducerId  String?
  createdByProducer    Producer?      @relation("CourtesyOrdersBy", fields: [createdByProducerId], references: [id], onDelete: SetNull)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  items                OrderItem[]
  issuedTickets        IssuedTicket[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventId    String
  eventSlug  String
  eventTitle String
  eventDate  String
  ticketId   String
  ticketName String
  unitPrice  Decimal @db.Decimal(10, 2)
  quantity   Int
}

model IssuedTicket {
  id                     String       @id @default(cuid())
  orderId                String
  order                  Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  code                   String       @unique
  eventId                String       @default("")
  eventSlug              String
  eventTitle    String
  eventDate     String
  eventTime     String
  venue         String
  city          String
  state         String
  ticketName    String
  lotLabel      String       @default("4º Lote")
  categoryLabel String       @default("Inteira")
  unitPrice     Decimal      @db.Decimal(10, 2)
  feeAmount     Decimal      @db.Decimal(10, 2)
  holderName    String
  holderEmail   String
  purchasedAt   DateTime     @default(now())
  source                 TicketSource @default(sale)
  status                 TicketStatus @default(approved)
  qrValue                String       @unique
  checkedInAt            DateTime?
  checkedInByOrganizerId String?
  checkedInByOrganizer   Organizer?   @relation("CheckedInBy", fields: [checkedInByOrganizerId], references: [id], onDelete: SetNull)
  createdByProducerId    String?
  createdByProducer      Producer?    @relation("CreatedByProducer", fields: [createdByProducerId], references: [id], onDelete: SetNull)
  transferCount          Int          @default(0)
  transferredAt          DateTime?
  transfers              TicketTransfer[]

  @@index([eventId])
  @@index([eventSlug])
  @@index([createdByProducerId])
  @@index([holderEmail])
}

model TicketTransfer {
  id                  String       @id @default(cuid())
  ticketId            String
  ticket              IssuedTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromName            String
  fromEmail           String
  toName              String
  toEmail             String
  transferredByUserId String?
  transferredByUser   User?        @relation("TransferInitiatedBy", fields: [transferredByUserId], references: [id], onDelete: SetNull)
  createdAt           DateTime     @default(now())

  @@index([ticketId])
  @@index([toEmail])
}
