{
  "name": "uai-tickets-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc",
    "start": "prisma db push --skip-generate && node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "email:test": "tsx scripts/test-email.ts",
    "email:test-ticket": "tsx scripts/test-ticket-email.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "prisma": "^6.19.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dejavu-fonts-ttf": "^2.37.3",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.5",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.15.32",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
